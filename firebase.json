{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": ["pnpm --prefix functions build"]
  },
  "hosting": {
    "public": "web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/cdn/**",
        "function": "cdnImage"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
