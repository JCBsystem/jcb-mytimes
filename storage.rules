rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Project files: only accessible by the user whose claim matches the path
    match /project/{projectKey}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.projectKey == projectKey;
    }
  }
}
