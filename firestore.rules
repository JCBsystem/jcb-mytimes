rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Project data: only accessible by the user whose claim matches the path
    match /project/{projectKey}/{path=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.projectKey == projectKey;
    }
  }
}
